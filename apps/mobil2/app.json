{
  "expo": {
    "name": "Soprano Mobil2",
    "slug": "sopranochat-mobil2",
    "version": "2.0.0",
    "orientation": "portrait",
    "scheme": "sopranochat-m2",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#060B18",
      "image": "./assets/splash-icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#060B18"
      },
      "package": "com.sopranochat.mobil2",
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.sopranochat.mobil2"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image-picker",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-google-signin/google-signin",
      "expo-apple-authentication",
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": false,
          "microphonePermission": "Odalarda diğer kullanıcılarla sesli sohbet edebilmeniz için mikrofona ihtiyacımız var."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c31167ef-cf8e-4d62-b45f-d0b47ad644b3"
      }
    }
  }
}
